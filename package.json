{
  "name": "videouniquer-pro",
  "version": "1.0.0",
  "description": "VideoUniquer Pro — десктопное приложение для уникализации видео",
  "main": "electron/main.js",
  "author": "VideoUniquer",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:frontend": "vite build",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win --config electron-builder.yml",
    "build:mac": "vite build && electron-builder --mac --config electron-builder.yml",
    "preview": "vite preview"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.videouniquer.pro",
    "productName": "VideoUniquer Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources/bin/win", "to": "bin/win", "filter": ["**/*"] },
      { "from": "resources/bin/mac", "to": "bin/mac", "filter": ["**/*"] },
      { "from": "resources/bin/linux", "to": "bin/linux", "filter": ["**/*"] }
    ],
    "win": {
      "target": ["nsis"],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
